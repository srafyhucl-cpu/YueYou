# Android 签名配置模板
# 1. 复制此文件为 key.properties
# 2. 用 keytool 生成 keystore:
#    keytool -genkey -v -keystore yueyou-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias yueyou
# 3. 将 yueyou-release.jks 放入 android/ 目录
# 4. 填写下方密码（注意：key.properties 已在 .gitignore 中，不会被提交）

storeFile=yueyou-release.jks
storePassword=你的密钥库密码
keyAlias=yueyou
keyPassword=你的密钥密码
