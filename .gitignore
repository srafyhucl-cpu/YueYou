# ===========================
# 全局忽略规则
# ===========================

# -------- Go 编译产物 --------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# -------- 数据库文件（含用户数据，禁止提交）--------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# -------- IDE --------
.idea/
.vscode/

# -------- OS --------
.DS_Store
Thumbs.db

# -------- 环境变量（含密钥，禁止提交）--------
.env
.env.*
!.env.example
